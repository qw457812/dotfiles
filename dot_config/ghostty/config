# see: `ghostty +show-config --default --docs`

font-family = "Maple Mono NF CN"
font-feature = "+cv35, +cv61, +cv62, +ss06"
font-size = 12

mouse-hide-while-typing = true
quit-after-last-window-closed = true

macos-option-as-alt = true
macos-titlebar-style = tabs
macos-window-buttons = hidden

keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:bottom
keybind = performable:ctrl+k=goto_split:top
keybind = performable:ctrl+l=goto_split:right
keybind = super+m=toggle_split_zoom
keybind = super+enter=new_split:auto
keybind = super+space=write_screen_file:open,vt
keybind = super+k=previous_tab
keybind = super+j=next_tab
# keybind = super+r=reload_config
keybind = super+u=scroll_page_fractional:-0.5
keybind = super+d=scroll_page_fractional:0.5

copy-on-select = clipboard
right-click-action = paste

# see: `ghostty +list-themes --color=dark`
theme = TokyoNight Moon
background-image = ~/.config/wall3.png
background-image-opacity = 0.125
background-image-fit = cover

# cursor-invert-fg-bg = true
adjust-cursor-thickness = 2
