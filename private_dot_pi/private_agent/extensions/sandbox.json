{
  "enableWeakerNetworkIsolation": true, // in favor of `gh`
  "network": {
    "allowedDomains": [
      // Package registries
      "npmjs.org",
      "*.npmjs.org",
      "registry.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "files.pythonhosted.org",
      "rubygems.org",
      "*.rubygems.org",
      // GitHub
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com",
      // Bun
      "bun.sh",
      "*.bun.sh",
      // LLM APIs
      "*.googleapis.com",
      "*.google.com",
      "*.anthropic.com",
      "*.openai.com"
    ]
  },
  "filesystem": {
    "allowWrite": [
      ".",
      "/tmp",
      "/private/tmp",
      "/var/folders",
      "/private/var/folders",
      "~/.npm",
      "~/.bun",
      "~/.cache" // in favor of `/skill:librarian`
    ]
  }
}
