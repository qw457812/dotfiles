{
  "excludedCommands": [
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/start.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/nav.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/eval.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/screenshot.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/emulate.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/pick.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/dismiss-cookies.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/watch.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/logs-tail.js:*",
    "~/.pi/agent/git/github.com/mitsuhiko/agent-stuff/skills/web-browser/scripts/net-summary.js:*"
  ],
  "sandboxRuntime": {
    "enableWeakerNetworkIsolation": true, // in favor of `gh`
    "allowPty": true, // in favor of `/skill:tmux`
    "network": {
      "allowedDomains": [
        // Package registries
        "npmjs.org",
        "*.npmjs.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "rubygems.org",
        "*.rubygems.org",
        // Bun
        "bun.sh",
        "*.bun.sh",
        // GitHub
        "github.com",
        "*.github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        // GitLab
        "gitlab.com",
        // LLM APIs
        "*.googleapis.com",
        "*.google.com",
        "*.anthropic.com",
        "*.openai.com"
      ],
      "allowUnixSockets": [
        "/tmp/claude/claude-tmux-sockets", // in favor of `/skill:tmux`
        "/tmp/claude-tmux-sockets",
        "/private/tmp/claude-tmux-sockets"
      ]
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "/private/tmp",
        "/var/folders",
        "/private/var/folders",
        "~/.npm",
        "~/.bun",
        "~/.cache", // in favor of `/skill:librarian`
        "~/.local/share/nvim/lazy" // in favor of `/skill:lazy-update-review` (partial-clone pack fetch from `git diff <installed>..<target>`)
      ]
    }
  },
  "justBash": {
    "hostCommands": [
      "git",
      "gh",
      "tmux" // in favor of `/skill:tmux`
    ],
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "/private/tmp",
        "/var/folders",
        "/private/var/folders",
        "~/.npm",
        "~/.bun",
        "~/.cache"
      ]
    },
    "network": {
      "allowedMethods": ["GET", "HEAD", "POST"],
      "allowedUrlPrefixes": [
        // Package registries
        "https://npmjs.org",
        "https://registry.npmjs.org",
        "https://registry.yarnpkg.com",
        "https://pypi.org",
        "https://files.pythonhosted.org",
        "https://rubygems.org",
        "https://index.rubygems.org",
        // Bun
        "https://bun.sh",
        // GitHub
        "https://github.com",
        "https://api.github.com",
        "https://codeload.github.com",
        "https://raw.githubusercontent.com",
        // GitLab
        "https://gitlab.com",
        // LLM APIs
        "https://generativelanguage.googleapis.com",
        "https://oauth2.googleapis.com",
        "https://api.anthropic.com",
        "https://api.openai.com"
      ]
    },
    // Sandboxed WASM runtimes (in-process, same FS/network policy):
    // `python3`/`python` (CPython Emscripten), `js-exec` + `node` stub (QuickJS).
    "python": true,
    "javascript": true
  }
}
