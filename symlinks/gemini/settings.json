{
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "preferredEditor": "neovim",
    "vimMode": true,
    "previewFeatures": true,
    "enableAutoUpdate": false,
    "enableNotifications": true
  },
  "context": {
    "fileName": [
      "CLAUDE.md",
      "CLAUDE.local.md",
      "GEMINI.md"
    ]
  },
  "ui": {
    "hideBanner": true,
    "theme": "GitHub",
    "footer": {
      "hideContextPercentage": false,
      "items": [
        "sandbox",
        "model-name",
        "context-used",
        "quota"
      ]
    }
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "tools": {
    "useRipgrep": true
  }
}